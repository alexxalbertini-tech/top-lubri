rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "alexx.albertini@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidBudget(data) {
      return hasRequiredFields(['userId', 'clientName', 'totalGeneral', 'date', 'status']) &&
             data.userId == request.auth.uid &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() < 100 &&
             data.totalGeneral is number &&
             data.status in ['draft', 'sent', 'approved'];
    }

    function isValidAppointment(data) {
      return hasRequiredFields(['userId', 'clientName', 'service', 'date', 'time', 'status']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'completed', 'cancelled'];
    }

    function isValidServiceRecord(data) {
      return hasRequiredFields(['userId', 'clientName', 'value', 'paymentMethod', 'date']) &&
             data.userId == request.auth.uid;
    }

    function isValidCashFlowEntry(data) {
      return hasRequiredFields(['userId', 'type', 'value', 'description', 'paymentMethod', 'date']) &&
             data.userId == request.auth.uid &&
             data.type in ['entry', 'exit'];
    }

    function isValidUserProfile(data) {
      return hasRequiredFields(['uid', 'email']) &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUserProfile(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && isValidUserProfile(request.resource.data);

      match /agendamentos/{id} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidAppointment(request.resource.data);
        allow update: if (isOwner(uid) || isAdmin()) && isValidAppointment(request.resource.data);
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /servicos/{id} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidServiceRecord(request.resource.data);
        allow update: if (isOwner(uid) || isAdmin()) && isValidServiceRecord(request.resource.data);
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /caixa/{id} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidCashFlowEntry(request.resource.data);
        allow update: if (isOwner(uid) || isAdmin()) && isValidCashFlowEntry(request.resource.data);
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /orcamentos/{id} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidBudget(request.resource.data);
        allow update: if (isOwner(uid) || isAdmin()) && isValidBudget(request.resource.data);
        allow delete: if isOwner(uid) || isAdmin();
      }
    }
  }
}
